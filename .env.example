# Copy to .env and fill in values
# Never commit .env to git

# Phoenix
SECRET_KEY_BASE=change_me_generate_with_mix_phx_gen_secret
PHX_HOST=localhost
PORT=4000

# Torznab/Newznab API authentication
# Comma-separated list of valid API keys (empty = no auth required)
# TAILORR_API_KEYS=key1,key2,key3

# Database
# Dev uses SQLite by default; DATABASE_URL overrides it
DATABASE_URL=ecto://tailorr:tailorr@db/tailorr_dev
# Production only (SQLite path for releases)
# DATABASE_PATH=/app/data/tailorr.db
# POOL_SIZE=5

# FlareSolverr (Cloudflare bypass)
FLARESOLVERR_URL=http://flaresolverr:8191

# Browser service (Playwright, for tracker builder and JS-heavy sites)
BROWSER_URL=http://localhost:3001

# Telegram CAPTCHA solver
# Get bot token from @BotFather on Telegram
# Users register by sending /start to your bot — no TELEGRAM_CHAT_ID needed
# TELEGRAM_BOT_TOKEN=123456789:ABCdefGHIjklMNOpqrSTUvwxYZ

# Logging
LOG_LEVEL=info

# Tracker credentials — add one pair per private tracker
# Format: TRACKER_USERNAME_<TRACKER_ID> and TRACKER_PASSWORD_<TRACKER_ID>
# TRACKER_USERNAME_MY_PRIVATE_TRACKER=myuser
# TRACKER_PASSWORD_MY_PRIVATE_TRACKER=mypassword

# Tracker API keys — add one per API-authenticated tracker
# Format: TRACKER_API_KEY_<TRACKER_ID>
# TRACKER_API_KEY_MY_API_TRACKER=abc123
