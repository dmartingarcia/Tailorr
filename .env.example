# Copy to .env and fill in values
# Never commit .env to git

# Phoenix
SECRET_KEY_BASE=change_me_generate_with_mix_phx_gen_secret
TAILORR_API_KEY=change_me_choose_a_strong_key
PHX_HOST=localhost

# Database (overridden in docker-compose.yml for local dev)
DATABASE_URL=ecto://tailorr:tailorr@db/tailorr_dev

# FlareSolverr (overridden in docker-compose.yml for local dev)
FLARESOLVERR_URL=http://flaresolverr:8191

# Logging
LOG_LEVEL=info

# Tracker credentials — add one pair per private tracker
# Format: TRACKER_USERNAME_<TRACKER_ID> and TRACKER_PASSWORD_<TRACKER_ID>
# TRACKER_USERNAME_MY_PRIVATE_TRACKER=myuser
# TRACKER_PASSWORD_MY_PRIVATE_TRACKER=mypassword

# Tracker API keys
# Format: TRACKER_APIKEY_<TRACKER_ID>
# TRACKER_APIKEY_MY_API_TRACKER=abc123
